      "delete": {
        "tags": ["Jobs"],
        "description": "Delete a job posting",
        "parameters": [
          {
            "name": "jobId",
            "in": "path",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "Job Deleted",
            "schema": {
              "type": "object",
              "properties": {
                "message": {
                  "type": "string"

  "paths": {
    "/health/": {
      "get": {
        "tags": ["Health"],
        "description": "Checking if the server and other functions are active",
        "responses": {
          "200": {
            "description": "Server is healthy",
            "schema": {
              "type": "object",
              "properties": {
                "message": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "/jobs/": {
      "get": {
        "tags": ["Jobs"],
        "description": "Retrieve all job postings",
        "responses": {
          "200": {
            "description": "List of jobs",
            "schema": {
              "type": "object",
              "properties": {
                "message": {
                  "type": "string"
                },
                "jobs": {
                  "type": "array",
                  "items": {
                    "$ref": "#/definitions/Job"
                  }
                }
              }
            }
          },
          "404": {
            "description": "No jobs found"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      },
      "post": {
        "tags": ["Jobs"],
        "description": "Create a new job posting",
        "parameters": [
          {
            "name": "job",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/Job"
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Job posting created",
            "schema": {
              "type": "object",
              "properties": {
                "message": {
                  "type": "string"
                },
                "job": {
                  "$ref": "#/definitions/Job"
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      },
      "put": {
        "tags": ["Jobs"],
        "description": "Update a job posting",
        "parameters": [
          {
            "name": "jobId",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "job",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/Job"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Job posting updated",
            "schema": {
              "type": "object",
              "properties": {
                "message": {
                  "type": "string"
                },
                "updatedJob": {
                  "$ref": "#/definitions/Job"
